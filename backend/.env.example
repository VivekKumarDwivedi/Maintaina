# Backend environment configuration for Society Maintenance Tracker

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Database (SQLite)
DB_PATH=./database.sqlite

# Email (Nodemailer)
# If EMAIL_USER and EMAIL_PASS are left empty, the app uses Ethereal for preview email.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="Society Maintenance <your_email@gmail.com>"

# Overdue detection threshold
OVERDUE_THRESHOLD_DAYS=7

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
